# Anthropic API (OpenAI-compatible endpoint)
# Copy this file to .env.anthropic and fill in your API key:
#   cp .env.anthropic.example .env.anthropic
LLM_GATEWAY_ENDPOINT=https://api.anthropic.com/v1/
LLM_GATEWAY_AUTH_TOKEN=sk-ant-REPLACE-WITH-YOUR-ANTHROPIC-API-KEY
LLM_MODEL=claude-sonnet-4-6-20250514

# Backend services (same as .env)
SESSION_SERVICE_URL=http://localhost:8000
WORKSPACE_SERVICE_URL=http://localhost:8002
