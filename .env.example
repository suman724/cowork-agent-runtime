# LLM Gateway (include /v1 suffix for OpenAI-compatible endpoints)
LLM_GATEWAY_ENDPOINT=http://localhost:8080/v1
LLM_GATEWAY_AUTH_TOKEN=your-token-here

# Backend services
SESSION_SERVICE_URL=http://localhost:8000
WORKSPACE_SERVICE_URL=http://localhost:8002

# Optional
# CHECKPOINT_DIR=/path/to/checkpoints
# APPROVAL_TIMEOUT_SECONDS=300
# LOG_LEVEL=info
# LLM_MODEL=openai/gpt-4o
# LLM_GATEWAY_HEADERS={"X-Custom-Header": "value"}

# Checkpoint / recovery
# WORKSPACE_SYNC_INTERVAL=5   # Sync to workspace every N steps (0 = disabled)

# Web search (optional — required for WebSearch tool)
# TAVILY_API_KEY=tvly-your-key-here
